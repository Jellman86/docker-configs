# Minimal environment for security_inference_stack/docker-compose.yml
#
# Copy to .env on the Docker host and adjust the values for that machine.
# The external Docker network `general_brg` must already exist.

# Host path where this stack stores service config/data.
DOCKERCONFIGPATH=/home/your-user/docker/security_inference_stack

# Host user/group used by mosquitto and YA-WAMF for file permissions.
PUID=1000
PGID=1000

# Local timezone used by all services.
TZ=Europe/London

# Frigate RTSP password used by your Frigate camera/restream config.
FRIGATE_RTSP_PASSWORD=change-me

# BirdNET-Go location filter.
BN_LAT=51.5074
BN_LONG=-0.1278

# Optional: BirdNET-Go web UI host port.
BN_WEBPORT=8080
