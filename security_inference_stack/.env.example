PUID=1000
PGID=1000
TZ=Europe/London
DOCKERCONFIGPATH=/mnt/apps/docker
SECURITY_EXPORT_PATH=/mnt/apps/security_inference_stack
SECURITY_STACK_UID=1000
SECURITY_STACK_GID=1000
RENDER_GID=105
LIBVA_DRIVER_NAME=iHD
LIBVA_DRIVERS_PATH=/usr/lib/x86_64-linux-gnu/dri

# Required before Frigate starts with camera configs that use RTSP auth.
FRIGATE_RTSP_PASSWORD=

# BirdNET-Go location settings for 3 Bank Street, DE55 4JE.
BN_WEBPORT=8080
BN_LAT=53.078237
BN_LONG=-1.367943

# YA-WAMF integration defaults.
FRIGATE_URL=http://frigate:5000
FRIGATE_AUTH_TOKEN=
MQTT_SERVER=mosquitto
MQTT_PORT=1883
MQTT_AUTH=true
MQTT_USERNAME=
MQTT_PASSWORD=
BIRDNET_URL=http://birdnet-go:8080
BIRDNET_EXTERNAL_URL=
YAWAMF_AUDIO_TOPIC=birdnet
DEBUG_UI_ENABLED=false
