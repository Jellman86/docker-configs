PUID=1000
PGID=1000
TZ=Europe/London
DOCKERCONFIGPATH=/mnt/apps/docker
SECURITY_EXPORT_PATH=/mnt/apps/security_inference_stack
SECURITY_STACK_UID=1000
SECURITY_STACK_GID=1000
RENDER_GID=105
LIBVA_DRIVER_NAME=iHD
LIBVA_DRIVERS_PATH=/usr/lib/x86_64-linux-gnu/dri

# Required before Frigate starts with camera configs that use RTSP auth.
FRIGATE_RTSP_PASSWORD=

# BirdNET-Go location settings for 3 Bank Street, DE55 4JE.
BN_WEBPORT=8080
BN_LAT=53.078237
BN_LONG=-1.367943

# BirdNET-Go detection tuning — optimised for Reolink RLC-520A camera mics (16 kHz mono AAC).
# These override the compose defaults; leave unset to use the defaults baked into docker-compose.yml.
BIRDNET_SENSITIVITY=1.0              # 0.1-1.5; keep 1.0 — raising it on a noisy camera mic mostly adds false positives
BIRDNET_THRESHOLD=0.7               # 0.0-1.0 confidence threshold
BIRDNET_OVERLAP=2.7                 # 0.0-2.9s; 2.7 = high recall for a continuous stream (plenty of CPU headroom)
BIRDNET_THREADS=4                   # inference threads; 4 keeps real-time at overlap 2.7 across 2 streams
BIRDNET_RANGEFILTER_THRESHOLD=0.03  # restrict to locally-plausible species; cuts false positives from the noisy mic
# NOTE: the audio high-pass EQ (200 Hz, to cut wind/rumble) has no env var — it lives in
# birdnet-go/config/config.yaml (realtime.audio.equalizer) and persists via the bind mount.

# YA-WAMF integration defaults.
FRIGATE_URL=http://frigate:5000
FRIGATE_AUTH_TOKEN=
MQTT_SERVER=mosquitto
MQTT_PORT=1883
MQTT_AUTH=true
MQTT_USERNAME=
MQTT_PASSWORD=
BIRDNET_URL=http://birdnet-go:8080
BIRDNET_EXTERNAL_URL=
YAWAMF_AUDIO_TOPIC=birdnet
DEBUG_UI_ENABLED=false
