PUID=1000
PGID=1000
TZ=Europe/London
HERMES_TIMEZONE=Europe/London
DOCKERCONFIGPATH=/mnt/apps/docker

HERMES_CPUS=2.0
HERMES_MEMORY_LIMIT=4g
HERMES_DASHBOARD_BIND=127.0.0.1
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_PUBLIC_URL=https://hermes.pownet.uk
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=replace-with-a-random-password
HERMES_DASHBOARD_BASIC_AUTH_SECRET=replace-with-at-least-32-random-bytes

TERMINAL_SSH_HOST=host.docker.internal
TERMINAL_SSH_USER=jellman86
TERMINAL_SSH_PORT=22
HERMES_HOST_WORKDIR=/home/jellman86
HERMES_HOST_SUDO_PASSWORD=

HASS_URL=http://host.docker.internal:8123
HASS_TOKEN=

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OpenViking persistent memory. Store all five key values as Dockhand secrets.
OPENVIKING_ROOT_API_KEY=replace-with-64-random-hex-characters
OPENVIKING_HERMES_KEY_SEED=replace-with-64-random-hex-characters
OPENVIKING_API_KEY=derive-from-hermes-user-and-key-seed
OPENVIKING_CODEX_KEY_SEED=replace-with-64-random-hex-characters
OPENVIKING_CODEX_API_KEY=derive-from-codex-user-and-key-seed
OPENVIKING_VLM_MODEL=gpt-5.6-luna
OPENVIKING_VLM_REASONING_EFFORT=low
OPENVIKING_CPUS=1.5
OPENVIKING_MEMORY_LIMIT=3g
OPENVIKING_OLLAMA_CPUS=1.0
OPENVIKING_OLLAMA_MEMORY_LIMIT=2g

# Official Microsoft Playwright MCP sidecar (headless Chromium).
PLAYWRIGHT_MCP_CPUS=1.5
PLAYWRIGHT_MCP_MEMORY_LIMIT=2g

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
GATEWAY_ALLOWED_USERS=

# Read-only Rusty IMAP MCP iCloud sidecar. Store this as a Dockhand secret.
RUSTY_IMAP_MCP_IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx
